{
  "name": "rescuesport-rules-portal",
  "compatibility_date": "2026-02-21",
  "main": "worker.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "rescuesports.co.za/*", "zone_name": "rescuesports.co.za" },
    { "pattern": "www.rescuesports.co.za/*", "zone_name": "rescuesports.co.za" }
  ]
}
